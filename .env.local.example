# Optional. If omitted, the app uses the current browser origin.
VITE_HA_URL=http://homeassistant.local:8123

# Optional. If omitted, the app uses Home Assistant OAuth via getAuth().
# VITE_HA_TOKEN=your_long_lived_access_token_here

# Required when deploying under Home Assistant static files (/local/...).
VITE_BASE_PATH=/local/ha-wallpanel/
